{
    "name": "datahelm/crawler",
    "description": "Generic Scrapy-like web crawler for Laravel — auto-detects lists, pagination, fields, and supports API/SPA, infinite scroll, image downloading, dedup, resumable crawls, and pluggable output sinks.",
    "type": "library",
    "license": "MIT",
    "keywords": ["crawler", "scraper", "laravel", "web-scraping"],
    "authors": [
        {
            "name": "Murilo Livorato",
            "email": "murilolivorato@gmail.com"
        }
    ],
    "support": {
        "issues": "https://github.com/data-helm/crawler/issues",
        "source": "https://github.com/data-helm/crawler"
    },
    "require": {
        "php": "^8.3",
        "ext-dom": "*",
        "ext-libxml": "*",
        "guzzlehttp/guzzle": "^7.0",
        "laravel/framework": "^11.0 || ^12.0 || ^13.0",
        "symfony/dom-crawler": "^7.0 || ^8.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.5 || ^12.0"
    },
    "autoload": {
        "psr-4": {
            "DataHelm\\Crawler\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "DataHelm\\Crawler\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit --configuration phpunit.xml"
    },
    "extra": {
        "laravel": {
            "providers": [
                "DataHelm\\Crawler\\CrawlerServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
